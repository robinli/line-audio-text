PORT=3000

# LINE Official Account
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# Default: two_step. Use single_reply only for testing or short synchronous processing.
LINE_REPLY_MODE=two_step

# OpenAI Speech-to-Text
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

# Firebase Admin
# Option A: base64-encoded Firebase service account JSON, recommended for Zeabur env vars.
FIREBASE_SERVICE_ACCOUNT_BASE64=

# Option B: Google Application Default Credentials path, useful for local development.
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Firebase Storage is optional.
STORE_AUDIO=false
FIREBASE_STORAGE_BUCKET=
